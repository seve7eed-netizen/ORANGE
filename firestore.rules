rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Projects Collection: Publicly readable, writeable after passing structural validation rules
    match /projects/{projectId} {
      allow read, list: if true;
      
      allow create: if isValidProject(request.resource.data);
      
      allow update: if isValidProject(request.resource.data) 
                    && (request.resource.data.id == resource.data.id);
                    
      allow delete: if true;
    }

    // Structural model validation for Project items: relaxed to maximize compatibility and prevent write failures due to minor variations
    function isValidProject(p) {
      return p.id is string && p.id.size() >= 1 && p.id.size() <= 128
        && p.title is string && p.title.size() >= 1
        && p.client is string;
    }
  }
}
